# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here

# Server Port
PORT=3000

# Supabase Configuration (optional - falls back to JSON file)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (migration script ONLY - never expose in frontend)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# CORS (comma-separated additional origins for production)
# CORS_ORIGINS=https://sentimind.vercel.app

# Auth Rate Limiting
# SIGNUP_RATE_LIMIT=3    # per 15 min per IP
# LOGIN_RATE_LIMIT=5     # per 1 min per IP

# Migration Script
# LEGACY_USER_EMAIL=legacy@sentimind.local
# DRY_RUN=false
# BATCH_SIZE=50

# Gemini Model Settings
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TEMPERATURE=0.5
# GEMINI_MAX_OUTPUT_TOKENS=512
# GEMINI_THINKING_BUDGET=0

# Retry & Timeout
# GEMINI_MAX_RETRIES=3
# GEMINI_BASE_DELAY=1000
# GEMINI_TIMEOUT=30000

# Rate Limiting (POST /api/analyze)
# Free Tier: RATE_LIMIT_MAX=8 (10 RPM 이하)
# Tier 1: RATE_LIMIT_MAX=200 (300 RPM 중 65% 안전선)
# RATE_LIMIT_WINDOW=60000
# RATE_LIMIT_MAX=200

# Logging
# LOG_RETENTION_DAYS=7
# LOG_LEVEL=INFO

# Gemini API 가격 (USD per 1M tokens, 가격 변동 시 수정)
# GEMINI_PRICE_INPUT=0.15
# GEMINI_PRICE_OUTPUT=0.60
# GEMINI_PRICE_THINKING=3.50
